<mujoco model="hybrid_robot">
    <compiler angle="radian"/>
    <option gravity="0 0 0"/>

    <worldbody>
        <!-- ================= BASE ================= -->
        <body name="base_link" pos="0 0 0">
            <inertial pos="0 0 0"
                      mass="5.0"
                      diaginertia="0.05 0.05 0.05"/>

            <!-- FREE-FLOATING BASE: 6 DOF -->
            <joint name="base_free" type="free"/>

            <geom name="base_geom"
                  type="box"
                  size="0.05 0.05 0.05"
                  rgba="0.6 0.6 0.6 1"/>

            <!-- ================= ARM 1 ================= -->
            <body name="link1" pos="0 0 0">
                <inertial pos="0 0 0"
                          mass="1.0"
                          diaginertia="0.005 0.005 0.005"/>

                <joint name="joint1"
                       type="hinge"
                       axis="0 0 1"
                       range="-3.14 3.14"
                       limited="true"/>

                <geom name="link1_geom"
                      type="cylinder"
                      size="0.03 0.1"
                      pos="0.1 0 0"
                      zaxis="1 0 0"
                      rgba="0.2 0.4 0.9 1"/>

                <body name="link2" pos="0.2 0 0">
                    <inertial pos="0 0 0"
                              mass="1.0"
                              diaginertia="0.005 0.005 0.005"/>

                    <joint name="joint2"
                           type="hinge"
                           axis="0 0 1"
                           range="-3.14 3.14"
                           limited="true"/>

                    <geom name="link2_geom"
                          type="cylinder"
                          size="0.03 0.1"
                          pos="0.1 0 0"
                          zaxis="1 0 0"
                          rgba="0.2 0.9 0.4 1"/>
                </body>
            </body>

            <!-- ================= ARM 2 ================= -->
            <body name="link3" pos="0 0 0">
                <inertial pos="0 0 0"
                          mass="1.0"
                          diaginertia="0.005 0.005 0.005"/>

                <joint name="joint3"
                       type="hinge"
                       axis="0 0 1"
                       range="-3.14 3.14"
                       limited="true"/>

                <geom name="link3_geom"
                      type="cylinder"
                      size="0.03 0.1"
                      pos="-0.1 0 0"
                      zaxis="-1 0 0"
                      rgba="0.9 0.2 0.2 1"/>

                <body name="link4" pos="-0.2 0 0">
                    <inertial pos="0 0 0"
                              mass="1.0"
                              diaginertia="0.005 0.005 0.005"/>

                    <joint name="joint4"
                           type="hinge"
                           axis="0 0 1"
                           range="-3.14 3.14"
                           limited="true"/>

                    <geom name="link4_geom"
                          type="cylinder"
                          size="0.03 0.1"
                          pos="-0.1 0 0"
                          zaxis="-1 0 0"
                          rgba="0.9 0.9 0.3 1"/>
                </body>
            </body>
        </body>
    </worldbody>

    <!-- ================= ACTUATORS ================= -->
    <actuator>
        <!-- ONLY MANIPULATOR ACTUATION -->
        <velocity name="vel1" joint="joint1" kv="3" ctrlrange="-50 50"/>
        <velocity name="vel2" joint="joint2" kv="3" ctrlrange="-50 50"/>
        <velocity name="vel3" joint="joint3" kv="3" ctrlrange="-50 50"/>
        <velocity name="vel4" joint="joint4" kv="3" ctrlrange="-50 50"/>
    </actuator>

</mujoco>
