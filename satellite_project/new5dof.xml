<mujoco model="satellite_5dof">
  <option iterations="50" timestep="0.001" solver="PGS" gravity="0 0 -9.81" />

  <compiler angle="radian" meshdir="meshes" eulerseq="zyx" autolimits="true" />

  <default>
    <joint limited="true" damping="0.01" armature="0.01" frictionloss="0.01" />
    <geom condim="4" contype="1" conaffinity="15" friction="0.9 0.2 0.2" solref="0.001 2" />
    <motor ctrllimited="true" />
    <equality solref="0.001 2" />
    <default class="visualgeom">
      <geom material="visualgeom" condim="1" contype="0" conaffinity="0" />
    </default>
  </default>

  <worldbody>
    <light directional="true" diffuse="0.4 0.4 0.4" specular="0.1 0.1 0.1" pos="0 0 5.0" dir="0 0 -1" castshadow="false" />
    <light directional="true" diffuse="0.6 0.6 0.6" specular="0.2 0.2 0.2" pos="0 0 4" dir="0 0 -1" />
    <geom name="ground" type="plane" pos="0 0 0" size="100 100 0.001" quat="1 0 0 0" material="matplane" condim="3" conaffinity="15" />
    <camera name="fixed" pos="0 -3.0 0.5" xyaxes="1 0 0 0 0 1" />
    <camera name="track" mode="trackcom" pos="0 -3.0 0.5" xyaxes="1 0 0 0 0 1" />
    <body name="root" pos="0 0 -0.0" quat="1 0 0 0">
      <freejoint name="root" />
      <site name="imu" size="0.01" pos="0 0 0" />
      <body name="base">
        <inertial pos="0 0 0" mass="2" diaginertia="0.008 0.008 0.008" />
        <joint name="base_joint" pos="0 0 0" axis="0 0 1" />
        <geom size="0.1" rgba="0.6 0.6 0.8 1" contype="1" conaffinity="0" density="0" group="1" class="visualgeom" />
        <geom type="" rgba="0.6 0.6 0.8 1" />
        <body name="link1" pos="0.16 0 0">
          <inertial pos="0 0 0" mass="1" diaginertia="0.0012 0.0012 0.0006" />
          <joint name="joint1" pos="0 0 0" axis="0 0 1" />
          <geom size="0.03 0.1" quat="0.707105 0 0.707108 0" type="cylinder" rgba="0.2 0.4 0.9 1" contype="1" conaffinity="0" density="0" group="1" class="visualgeom" />
          <geom type="cylinder" rgba="0.2 0.4 0.9 1" quat="0.707105 0 0.707108 0" />
          <body name="link2" pos="0.2 0 0">
            <inertial pos="0 0 0" mass="1" diaginertia="0.0012 0.0012 0.0006" />
            <joint name="joint2" pos="0 0 0" axis="0 0 1" />
            <geom size="0.03 0.1" quat="0.707105 0 0.707108 0" type="cylinder" rgba="0.2 0.9 0.3 1" contype="1" conaffinity="0" density="0" group="1" class="visualgeom" />
            <geom type="cylinder" rgba="0.2 0.9 0.3 1" quat="0.707105 0 0.707108 0" />
          </body>
        </body>
        <body name="link3" pos="-0.16 0 0">
          <inertial pos="0 0 0" mass="1" diaginertia="0.0012 0.0012 0.0006" />
          <joint name="joint3" pos="0 0 0" axis="0 0 1" />
          <geom size="0.03 0.1" quat="0.707105 0 0.707108 0" type="cylinder" rgba="0.9 0.5 0.2 1" contype="1" conaffinity="0" density="0" group="1" class="visualgeom" />
          <geom type="cylinder" rgba="0.9 0.5 0.2 1" quat="0.707105 0 0.707108 0" />
          <body name="link4" pos="-0.2 0 0">
            <inertial pos="0 0 0" mass="1" diaginertia="0.0012 0.0012 0.0006" />
            <joint name="joint4" pos="0 0 0" axis="0 0 1" />
            <geom size="0.03 0.1" quat="0.707105 0 0.707108 0" type="cylinder" rgba="0.9 0.2 0.2 1" contype="1" conaffinity="0" density="0" group="1" class="visualgeom" />
            <geom type="cylinder" rgba="0.9 0.2 0.2 1" quat="0.707105 0 0.707108 0" />
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <asset>
    <texture name="texplane" type="2d" builtin="checker" rgb1=".0 .0 .0" rgb2=".8 .8 .8" width="100" height="100" />
    <material name="matplane" reflectance="0." texture="texplane" texrepeat="1 1" texuniform="true" />
    <material name="visualgeom" rgba="0.5 0.9 0.2 1" />
  </asset>

  <actuator>
    <motor name="base_joint" joint="base_joint" ctrllimited="true" ctrlrange="-1 1" gear="1" />
    <motor name="joint1" joint="joint1" ctrllimited="true" ctrlrange="-1 1" gear="1" />
    <motor name="joint2" joint="joint2" ctrllimited="true" ctrlrange="-1 1" gear="1" />
    <motor name="joint3" joint="joint3" ctrllimited="true" ctrlrange="-1 1" gear="1" />
    <motor name="joint4" joint="joint4" ctrllimited="true" ctrlrange="-1 1" gear="1" />
  </actuator>

  <sensor>
    <actuatorpos name="base_joint_p" actuator="base_joint" />
    <actuatorvel name="base_joint_v" actuator="base_joint" />
    <actuatorfrc name="base_joint_f" actuator="base_joint" noise="0.001" />
    <actuatorpos name="joint1_p" actuator="joint1" />
    <actuatorvel name="joint1_v" actuator="joint1" />
    <actuatorfrc name="joint1_f" actuator="joint1" noise="0.001" />
    <actuatorpos name="joint2_p" actuator="joint2" />
    <actuatorvel name="joint2_v" actuator="joint2" />
    <actuatorfrc name="joint2_f" actuator="joint2" noise="0.001" />
    <actuatorpos name="joint3_p" actuator="joint3" />
    <actuatorvel name="joint3_v" actuator="joint3" />
    <actuatorfrc name="joint3_f" actuator="joint3" noise="0.001" />
    <actuatorpos name="joint4_p" actuator="joint4" />
    <actuatorvel name="joint4_v" actuator="joint4" />
    <actuatorfrc name="joint4_f" actuator="joint4" noise="0.001" />
    <framequat name="orientation" objtype="site" noise="0.001" objname="imu" />
    <gyro name="angular-velocity" site="imu" noise="0.005" cutoff="34.9" />
  </sensor>
</mujoco>