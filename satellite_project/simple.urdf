<?xml version="1.0"?>
<robot name="simple_2dof_robot_with_two_arms">
  <!-- Base parent (world frame) -->
  <link name="world"/>

  <!-- Base link -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder length="0.1" radius="0.05"/>
      </geometry>
      <material name="gray">
        <color rgba="0.6 0.6 0.6 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.1" radius="0.05"/>
      </geometry>
    </collision>
  </link>

  <!-- Base joint: revolute joint connecting base_link to world -->
  <joint name="base_joint" type="revolute">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="2"/>
  </joint>

  <!-- Link 1 -->
  <link name="link1">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.005" iyy="0.005" izz="0.005" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0.1 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.03"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.4 0.9 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.1 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.03"/>
      </geometry>
    </collision>
  </link>

  <!-- Link 2 -->
  <link name="link2">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.005" iyy="0.005" izz="0.005" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0.1 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.03"/>
      </geometry>
      <material name="green">
        <color rgba="0.2 0.9 0.4 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.1 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.03"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint 1: connects base_link to link1 (POSITIVE X direction) -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="2"/>
  </joint>

  <!-- Joint 2: connects link1 to link2 -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0.2 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="2"/>
  </joint>

  <!-- Link 3: second arm, on the NEGATIVE X side -->
  <link name="link3">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.005" iyy="0.005" izz="0.005" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="-0.1 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.03"/>
      </geometry>
      <material name="red">
        <color rgba="0.9 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.1 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.03"/>
      </geometry>
    </collision>
  </link>

  <!-- Link 4: second arm's extension -->
  <link name="link4">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.005" iyy="0.005" izz="0.005" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="-0.1 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.03"/>
      </geometry>
      <material name="yellow">
        <color rgba="0.9 0.9 0.3 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.1 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.03"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint 3: connects base_link to link3 (NEGATIVE X direction) -->
  <joint name="joint3" type="revolute">
    <parent link="base_link"/>
    <child link="link3"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="2"/>
  </joint>

  <!-- Joint 4: connects link3 to link4 -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="-0.2 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="2"/>
  </joint>
</robot>

