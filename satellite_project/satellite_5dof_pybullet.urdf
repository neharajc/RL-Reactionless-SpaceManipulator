<?xml version="1.0"?>
<robot name="satellite_5dof">

  <!-- BASE: sphere connected to world via revolute joint (z-axis) -->
  <link name="world"/>
  
  <link name="base">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.008" iyz="0" izz="0.008"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><sphere radius="0.1"/></geometry>
      <material name="gray"><color rgba="0.6 0.6 0.8 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry><sphere radius="0.1"/></geometry>
    </collision>
  </link>

  <joint name="base_joint" type="revolute">
    <parent link="world"/>
    <child link="base"/>
    <origin xyz="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="5"/>
  </joint>

  <!-- Link properties: cuboids -->
  <link name="link1">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.0004" ixy="0" ixz="0" iyy="0.0035" iyz="0" izz="0.0035"/>
    </inertial>
    <visual>
      <geometry><box size="0.2 0.05 0.05"/></geometry>
      <material name="blue"><color rgba="0.2 0.4 0.9 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.2 0.05 0.05"/></geometry>
    </collision>
  </link>

  <link name="link2">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.0004" ixy="0" ixz="0" iyy="0.0035" iyz="0" izz="0.0035"/>
    </inertial>
    <visual>
      <geometry><box size="0.2 0.05 0.05"/></geometry>
      <material name="green"><color rgba="0.2 0.9 0.3 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.2 0.05 0.05"/></geometry>
    </collision>
  </link>

  <link name="link3">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.0004" ixy="0" ixz="0" iyy="0.0035" iyz="0" izz="0.0035"/>
    </inertial>
    <visual>
      <geometry><box size="0.2 0.05 0.05"/></geometry>
      <material name="orange"><color rgba="0.9 0.5 0.2 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.2 0.05 0.05"/></geometry>
    </collision>
  </link>

  <link name="link4">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.0004" ixy="0" ixz="0" iyy="0.0035" iyz="0" izz="0.0035"/>
    </inertial>
    <visual>
      <geometry><box size="0.2 0.05 0.05"/></geometry>
      <material name="red"><color rgba="0.9 0.2 0.2 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.2 0.05 0.05"/></geometry>
    </collision>
  </link>

  <!-- Joints -->
  <joint name="joint1" type="revolute">
    <parent link="base"/>
    <child link="link1"/>
    <origin xyz="0.16 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="5"/>
  </joint>

  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0.2 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="5"/>
  </joint>

  <joint name="joint3" type="revolute">
    <parent link="base"/>
    <child link="link3"/>
    <origin xyz="-0.16 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="5"/>
  </joint>

  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="-0.2 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="5"/>
  </joint>

</robot>
