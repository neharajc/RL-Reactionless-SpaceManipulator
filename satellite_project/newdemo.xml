<mujoco model="satellite_model">
  <option iterations="50" timestep="0.001" solver="PGS" gravity="0 0 -9.81" />

  <compiler angle="radian" meshdir="meshes" eulerseq="zyx" autolimits="true" />

  <default>
    <joint limited="true" damping="0.01" armature="0.01" frictionloss="0.01" />
    <geom condim="4" contype="1" conaffinity="15" friction="0.9 0.2 0.2" solref="0.001 2" />
    <motor ctrllimited="true" />
    <equality solref="0.001 2" />
    <default class="visualgeom">
      <geom material="visualgeom" condim="1" contype="0" conaffinity="0" />
    </default>
  </default>

  <worldbody>
    <light directional="true" diffuse="0.4 0.4 0.4" specular="0.1 0.1 0.1" pos="0 0 5.0" dir="0 0 -1" castshadow="false" />
    <light directional="true" diffuse="0.6 0.6 0.6" specular="0.2 0.2 0.2" pos="0 0 4" dir="0 0 -1" />
    <geom name="ground" type="plane" pos="0 0 0" size="100 100 0.001" quat="1 0 0 0" material="matplane" condim="3" conaffinity="15" />
    <camera name="fixed" pos="0 -3.0 0.55" xyaxes="1 0 0 0 0 1" />
    <camera name="track" mode="trackcom" pos="0 -3.0 0.55" xyaxes="1 0 0 0 0 1" />
    <body name="root" pos="0 0 0.05" quat="1 0 0 0">
      <freejoint name="root" />
      <site name="imu" size="0.01" pos="0 0 0" />
      <body name="base">
        <inertial pos="0 0 0" mass="1" diaginertia="0.032 0.032 0.032" />
        <joint name="base_revolute" pos="0 0 0" axis="0 0 1" range="-3.1416 3.1416" actuatorfrcrange="-100 100" />
        <geom size="0.2" rgba="0 0 1 1" contype="1" conaffinity="0" density="0" group="1" class="visualgeom" />
        <geom type="" rgba="0 0 1 1" />
        <body name="l2" pos="-0.2 0 0">
          <inertial pos="-0.5 0 0" quat="0.5 0.5 0.5 0.5" mass="1" diaginertia="0.0833 0.0833 0.00833" />
          <joint name="j2" pos="0 0 0" axis="0 0 1" range="-3.1416 3.1416" actuatorfrcrange="-100 100" />
          <geom size="0.5 0.05 0.05" pos="-0.5 0 0" type="box" rgba="0 1 0 1" contype="1" conaffinity="0" density="0" group="1" class="visualgeom" />
          <geom type="box" rgba="0 1 0 1" size="0.5 0.05 0.05" pos="-0.5 0 0" />
          <body name="l1" pos="-1 0 0">
            <inertial pos="-0.5 0 0" quat="0.5 0.5 0.5 0.5" mass="1" diaginertia="0.0833 0.0833 0.00833" />
            <joint name="j1" pos="0 0 0" axis="0 0 1" range="-3.1416 3.1416" actuatorfrcrange="-100 100" />
            <geom size="0.5 0.05 0.05" pos="-0.5 0 0" type="box" rgba="1 0 0 1" contype="1" conaffinity="0" density="0" group="1" class="visualgeom" />
            <geom type="box" rgba="1 0 0 1" size="0.5 0.05 0.05" pos="-0.5 0 0" />
          </body>
        </body>
        <body name="l3" pos="0.2 0 0">
          <inertial pos="0.5 0 0" quat="0.5 0.5 0.5 0.5" mass="1" diaginertia="0.0833 0.0833 0.00833" />
          <joint name="j3" pos="0 0 0" axis="0 0 1" range="-3.1416 3.1416" actuatorfrcrange="-100 100" />
          <geom size="0.5 0.05 0.05" pos="0.5 0 0" type="box" rgba="1 1 0 1" contype="1" conaffinity="0" density="0" group="1" class="visualgeom" />
          <geom type="box" rgba="1 1 0 1" size="0.5 0.05 0.05" pos="0.5 0 0" />
          <body name="l4" pos="1 0 0">
            <inertial pos="0.5 0 0" quat="0.5 0.5 0.5 0.5" mass="1" diaginertia="0.0833 0.0833 0.00833" />
            <joint name="j4" pos="0 0 0" axis="0 0 1" range="-3.1416 3.1416" actuatorfrcrange="-100 100" />
            <geom size="0.5 0.05 0.05" pos="0.5 0 0" type="box" rgba="0 1 1 1" contype="1" conaffinity="0" density="0" group="1" class="visualgeom" />
            <geom type="box" rgba="0 1 1 1" size="0.5 0.05 0.05" pos="0.5 0 0" />
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <asset>
    <texture name="texplane" type="2d" builtin="checker" rgb1=".0 .0 .0" rgb2=".8 .8 .8" width="100" height="100" />
    <material name="matplane" reflectance="0." texture="texplane" texrepeat="1 1" texuniform="true" />
    <material name="visualgeom" rgba="0.5 0.9 0.2 1" />
  </asset>

  <actuator>
    <motor name="base_revolute" joint="base_revolute" ctrllimited="true" ctrlrange="-100 100" gear="1" />
    <motor name="j2" joint="j2" ctrllimited="true" ctrlrange="-100 100" gear="1" />
    <motor name="j1" joint="j1" ctrllimited="true" ctrlrange="-100 100" gear="1" />
    <motor name="j3" joint="j3" ctrllimited="true" ctrlrange="-100 100" gear="1" />
    <motor name="j4" joint="j4" ctrllimited="true" ctrlrange="-100 100" gear="1" />
  </actuator>

  <sensor>
    <actuatorpos name="base_revolute_p" actuator="base_revolute" />
    <actuatorvel name="base_revolute_v" actuator="base_revolute" />
    <actuatorfrc name="base_revolute_f" actuator="base_revolute" noise="0.001" />
    <actuatorpos name="j2_p" actuator="j2" />
    <actuatorvel name="j2_v" actuator="j2" />
    <actuatorfrc name="j2_f" actuator="j2" noise="0.001" />
    <actuatorpos name="j1_p" actuator="j1" />
    <actuatorvel name="j1_v" actuator="j1" />
    <actuatorfrc name="j1_f" actuator="j1" noise="0.001" />
    <actuatorpos name="j3_p" actuator="j3" />
    <actuatorvel name="j3_v" actuator="j3" />
    <actuatorfrc name="j3_f" actuator="j3" noise="0.001" />
    <actuatorpos name="j4_p" actuator="j4" />
    <actuatorvel name="j4_v" actuator="j4" />
    <actuatorfrc name="j4_f" actuator="j4" noise="0.001" />
    <framequat name="orientation" objtype="site" noise="0.001" objname="imu" />
    <gyro name="angular-velocity" site="imu" noise="0.005" cutoff="34.9" />
  </sensor>
</mujoco>