<?xml version="1.0"?>
<robot name="satellite_model">

  <!-- World fixed frame -->
  <link name="world"/>

  <!-- Base link -->
  <link name="base">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1"/>
      <inertia ixx="0.032" ixy="0" ixz="0" iyy="0.032" iyz="0" izz="0.032"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.2"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.2"/>
      </geometry>
    </collision>
  </link>

  <!-- Base joint: base and world -->
  <joint name="base_revolute" type="revolute">
    <parent link="world"/>
    <child link="base"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" velocity="10" lower="-3.1416" upper="3.1416"/>
  </joint>

  <!-- Link l2 -->
  <link name="l2">
    <inertial>
      <origin xyz="-0.5 0 0"/>
      <mass value="1"/>
      <inertia ixx="0.00833" ixy="0" ixz="0" iyy="0.0833" iyz="0" izz="0.0833"/>
    </inertial>
    <visual>
      <origin xyz="-0.5 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1 0.1 0.1"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.5 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint j2: base -> l2 -->
  <joint name="j2" type="revolute">
    <parent link="base"/>
    <child link="l2"/>
    <origin xyz="-0.2 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" velocity="10" lower="-3.1416" upper="3.1416"/>
  </joint>

  <!-- Link l1 -->
  <link name="l1">
    <inertial>
      <origin xyz="-0.5 0 0"/>
      <mass value="1"/>
      <inertia ixx="0.00833" ixy="0" ixz="0" iyy="0.0833" iyz="0" izz="0.0833"/>
    </inertial>
    <visual>
      <origin xyz="-0.5 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1 0.1 0.1"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.5 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint j1: l2 -> l1 -->
  <joint name="j1" type="revolute">
    <parent link="l2"/>
    <child link="l1"/>
    <origin xyz="-1 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" velocity="10" lower="-3.1416" upper="3.1416"/>
  </joint>

  <!-- Link l3 -->
  <link name="l3">
    <inertial>
      <origin xyz="0.5 0 0"/>
      <mass value="1"/>
      <inertia ixx="0.00833" ixy="0" ixz="0" iyy="0.0833" iyz="0" izz="0.0833"/>
    </inertial>
    <visual>
      <origin xyz="0.5 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1 0.1 0.1"/>
      </geometry>
      <material name="yellow">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.5 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint j3: base -> l3 -->
  <joint name="j3" type="revolute">
    <parent link="base"/>
    <child link="l3"/>
    <origin xyz="0.2 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" velocity="10" lower="-3.1416" upper="3.1416"/>
  </joint>

  <!-- Link l4 -->
  <link name="l4">
    <inertial>
      <origin xyz="0.5 0 0"/>
      <mass value="1"/>
      <inertia ixx="0.00833" ixy="0" ixz="0" iyy="0.0833" iyz="0" izz="0.0833"/>
    </inertial>
    <visual>
      <origin xyz="0.5 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1 0.1 0.1"/>
      </geometry>
      <material name="cyan">
        <color rgba="0 1 1 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.5 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint j4: l3 -> l4 -->
  <joint name="j4" type="revolute">
    <parent link="l3"/>
    <child link="l4"/>
    <origin xyz="1 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" velocity="10" lower="-3.1416" upper="3.1416"/>
  </joint>
</robot>

